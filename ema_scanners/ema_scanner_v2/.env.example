# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ema_scanner

# Binance API (optional - public endpoints only needed)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Scanner settings
# COLLECT=0 means no volume filter — every coin gets candles stored.
# SIGNAL is the only real cutoff, applied when generating EMA signals.
MIN_VOLUME_USDT_COLLECT=0
MIN_VOLUME_USDT_SIGNAL=10000000
CANDLES_LIMIT=3000
CANDLE_INTERVAL=1h
EMA_SHORT=7
EMA_MID=25
EMA_LONG=99
CONVERGENCE_WINDOW=3

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
